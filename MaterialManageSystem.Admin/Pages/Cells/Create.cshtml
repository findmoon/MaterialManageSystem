@page
@model MaterialManageSystem.Admin.Pages.Cells.CreateModel
@{
    ViewData["Title"] = "新建单元格";
    ViewData["ActivePage"] = "Cells";
}

<div class="card">
    <div class="card-header">新建单元格</div>
    <div class="card-body">
        <form method="post">
            <div class="form-group">
                <label>单元格编码</label>
                <input asp-for="Input.Code" class="form-control" />
            </div>
            <div class="form-group">
                <label>行号</label>
                <input asp-for="Input.Row" type="number" class="form-control" />
            </div>
            <div class="form-group">
                <label>列号</label>
                <input asp-for="Input.Col" type="number" class="form-control" />
            </div>
            <div class="form-group">
                <label>库房</label>
                <select id="rackSelect" class="form-control" onchange="loadLayers()">
                    <option value="">请选择库房</option>
                    @foreach (var rack in Model.Racks)
                    {
                        <option value="@rack.Id">@rack.WarehouseCode / @rack.Code</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>层</label>
                <select asp-for="Input.LayerId" id="layerSelect" class="form-control">
                    <option value="">请先选择库房</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">创建</button>
            <a asp-page="/Cells" class="btn btn-secondary">取消</a>
        </form>
    </div>
</div>

<script>
    async function loadLayers() {
        var rackId = document.getElementById('rackSelect').value;
        var layerSelect = document.getElementById('layerSelect');
        
        if (!rackId) {
            layerSelect.innerHTML = '<option value="">请先选择库房</option>';
            return;
        }

        var response = await fetch(`/Cells/Create?handler=Layers&rackId=${rackId}`);
        var layers = await response.json();
        
        layerSelect.innerHTML = '<option value="">请选择层</option>';
        layers.forEach(function(layer) {
            var option = document.createElement('option');
            option.value = layer.id;
            option.textContent = layer.code;
            layerSelect.appendChild(option);
        });
    }
</script>