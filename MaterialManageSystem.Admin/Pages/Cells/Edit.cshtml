@page "{id}"
@model MaterialManageSystem.Admin.Pages.Cells.EditModel
@{
    ViewData["Title"] = "编辑单元格";
    ViewData["ActivePage"] = "Cells";
}

<div class="card">
    <div class="card-header">编辑单元格</div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="id" value="@Model.CellId" />
            <div class="form-group">
                <label>单元格编码</label>
                <input asp-for="Input.Code" class="form-control" />
            </div>
            <div class="form-group">
                <label>行号</label>
                <input asp-for="Input.Row" type="number" class="form-control" />
            </div>
            <div class="form-group">
                <label>列号</label>
                <input asp-for="Input.Col" type="number" class="form-control" />
            </div>
            <div class="form-group">
                <label>状态</label>
                <select asp-for="Input.IsActive" class="form-control">
                    <option value="true">启用</option>
                    <option value="false">禁用</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">保存</button>
            <a asp-page="/Cells" class="btn btn-secondary">取消</a>
        </form>
    </div>
</div>