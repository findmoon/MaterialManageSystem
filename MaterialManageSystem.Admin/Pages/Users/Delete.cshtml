@page
@model MaterialManageSystem.Admin.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "删除用户";
}

<div class="card">
    <div class="card-header">
        <h5>删除用户</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (Model.User != null)
        {
            <div class="alert alert-warning">
                <strong>警告：</strong> 确定要删除用户 "@Model.User.Username" 吗？此操作不可撤销。
            </div>

            <table class="table">
                <tr>
                    <th>用户名</th>
                    <td>@Model.User.Username</td>
                </tr>
                <tr>
                    <th>员工编号</th>
                    <td>@Model.User.EmployeeNo</td>
                </tr>
                <tr>
                    <th>员工姓名</th>
                    <td>@Model.User.EmployeeName</td>
                </tr>
                <tr>
                    <th>用户类型</th>
                    <td>@Model.User.UserTypeName</td>
                </tr>
            </table>

            <form method="post">
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">确认删除</button>
                    <a asp-page="Index" class="btn btn-secondary">取消</a>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-danger">用户不存在</div>
            <a asp-page="Index" class="btn btn-secondary">返回列表</a>
        }
    </div>
</div>
