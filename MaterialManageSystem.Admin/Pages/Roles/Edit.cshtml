@page "{id}"
@model MaterialManageSystem.Admin.Pages.Roles.EditModel
@{
    ViewData["Title"] = "编辑角色";
    ViewData["ActivePage"] = "Roles";
}

<div class="card">
    <div class="card-header">编辑角色</div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="id" value="@Model.RoleId" />
            <div class="form-group">
                <label>角色名称</label>
                <input asp-for="Input.Name" class="form-control" />
            </div>
            <div class="form-group">
                <label>描述</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label>状态</label>
                <select asp-for="Input.IsActive" class="form-control">
                    <option value="true">启用</option>
                    <option value="false">禁用</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">保存</button>
            <a asp-page="/Roles" class="btn btn-secondary">取消</a>
        </form>
    </div>
</div>