@page
@model MaterialManageSystem.Admin.Pages.Employees.DeleteModel
@{
    ViewData["Title"] = "删除员工";
}

<div class="card">
    <div class="card-header">
        <h5>删除员工</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (Model.Employee != null)
        {
            <div class="alert alert-warning">
                <strong>警告：</strong> 确定要删除员工 "@Model.Employee.Name (@Model.Employee.EmployeeNo)" 吗？此操作不可撤销。
            </div>

            <table class="table">
                <tr>
                    <th>员工编号</th>
                    <td>@Model.Employee.EmployeeNo</td>
                </tr>
                <tr>
                    <th>姓名</th>
                    <td>@Model.Employee.Name</td>
                </tr>
                <tr>
                    <th>部门</th>
                    <td>@(Model.Employee.Department ?? "-")</td>
                </tr>
                <tr>
                    <th>职位</th>
                    <td>@(Model.Employee.Position ?? "-")</td>
                </tr>
                <tr>
                    <th>电话</th>
                    <td>@(Model.Employee.Phone ?? "-")</td>
                </tr>
                <tr>
                    <th>邮箱</th>
                    <td>@(Model.Employee.Email ?? "-")</td>
                </tr>
                <tr>
                    <th>关联用户</th>
                    <td>
                        <span class="badge @(Model.Employee.HasUser ? "bg-info text-white" : "bg-secondary text-white")">
                            @(Model.Employee.HasUser ? "已关联" : "未关联")
                        </span>
                    </td>
                </tr>
            </table>

            <form method="post">
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">确认删除</button>
                    <a asp-page="/Employees" class="btn btn-secondary">取消</a>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-danger">员工不存在</div>
            <a asp-page="/Employees" class="btn btn-secondary">返回列表</a>
        }
    </div>
</div>
