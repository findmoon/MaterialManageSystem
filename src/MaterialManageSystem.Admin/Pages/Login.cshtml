@page
@model MaterialManageSystem.Admin.Pages.LoginModel
@{
    ViewData["Title"] = "登录";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">物料管理系统</h3>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    <form method="post">
                        <div class="form-group">
                            <label for="Username">用户名</label>
                            <input asp-for="Username" class="form-control" placeholder="请输入用户名" required />
                        </div>
                        <div class="form-group">
                            <label for="Password">密码</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="请输入密码" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-block mt-4">登录</button>
                        <div class="text-center mt-3">
                            <a asp-page="/Register">没有账号？立即注册</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>