@page
@model MaterialManageSystem.Admin.Pages.UsersModel
@{
    ViewData["Title"] = "用户管理";
    ViewData["ActivePage"] = "Users";
}

<a asp-page="/Users/Create" class="btn btn-primary mb-3">
    <i class="fas fa-plus"></i> 新建用户
</a>

<div class="card">
    <div class="card-header">用户列表</div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>用户名</th>
                    <th>员工编号</th>
                    <th>员工姓名</th>
                    <th>用户类型</th>
                    <th>状态</th>
                    <th>最后登录</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.EmployeeNo</td>
                        <td>@user.EmployeeName</td>
                        <td>
                            <span class="badge @GetUserTypeClass(user.UserType)">
                                @GetUserTypeName(user.UserType)
                            </span>
                        </td>
                        <td>
                            <span class="badge @(user.IsActive ? "bg-success text-white" : "bg-secondary text-white")">
                                @(user.IsActive ? "启用" : "禁用")
                            </span>
                        </td>
                        <td>@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td>
                            <a asp-page="/Users/Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> 编辑
                            </a>
                            <a asp-page="/Users/Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> 删除
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    private string GetUserTypeName(int userType)
    {
        return userType switch
        {
            0 => "普通用户",
            1 => "管理员",
            2 => "系统管理员",
            _ => "未知"
        };
    }

    private string GetUserTypeClass(int userType)
    {
        return userType switch
        {
            0 => "bg-info text-white",
            1 => "bg-warning text-dark",
            2 => "bg-danger text-white",
            _ => "bg-secondary text-white"
        };
    }
}
