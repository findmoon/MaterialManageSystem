@page
@model MaterialManageSystem.Admin.Pages.OperationLogsModel
@{
    ViewData["Title"] = "操作日志";
    ViewData["ActivePage"] = "OperationLogs";
}

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between">
            <h5>操作日志列表</h5>
            <form method="get" class="form-inline">
                <input type="text" name="Keyword" class="form-control mr-2" placeholder="搜索关键词" value="@Model.Keyword" />
                <button type="submit" class="btn btn-primary">搜索</button>
            </form>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>时间</th>
                    <th>操作类型</th>
                    <th>控制器</th>
                    <th>方法</th>
                    <th>请求路径</th>
                    <th>状态码</th>
                    <th>执行时间(ms)</th>
                    <th>操作用户</th>
                    <th>IP地址</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(log.OperationType ?? "-")</td>
                        <td>@(log.ControllerName ?? "-")</td>
                        <td>@(log.ActionName ?? "-")</td>
                        <td>
                            <span class="text-primary">@log.RequestMethod</span> @(log.RequestPath ?? "-")
                        </td>
                        <td>
                            <span class="badge @GetStatusCodeClass(log.StatusCode)">@log.StatusCode</span>
                        </td>
                        <td>@(log.ExecutionTime ?? 0)</td>
                        <td>@(log.UserName ?? "-")</td>
                        <td>@(log.IpAddress ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Total > 0)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.Page - 1)&keyword=@Model.Keyword">上一页</a>
                    </li>
                    @for (int i = 1; i <= Math.Ceiling((double)Model.Total / Model.PageSize); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="?page=@i&keyword=@Model.Keyword">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Math.Ceiling((double)Model.Total / Model.PageSize) ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.Page + 1)&keyword=@Model.Keyword">下一页</a>
                    </li>
                </ul>
            </nav>
            <p class="text-center text-muted">共 @Model.Total 条记录</p>
        }
        else
        {
            <div class="text-center text-muted py-4">暂无记录</div>
        }
    </div>
</div>

@functions {
    private string GetStatusCodeClass(int? statusCode)
    {
        if (!statusCode.HasValue) return "bg-secondary text-white";
        if (statusCode.Value >= 200 && statusCode.Value < 300) return "bg-success text-white";
        if (statusCode.Value >= 400 && statusCode.Value < 500) return "bg-warning text-white";
        if (statusCode.Value >= 500) return "bg-danger text-white";
        return "bg-secondary text-white";
    }
}
